# Frontend Environment Variables (VITE_ prefix for client-side access)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# VITE_GEMINI_API_TOKEN is deprecated. Use VITE_GEMINI_API_KEY.

# Firebase Configuration (Requirements: 2.1, 2.2, 2.6)
# Get these values from your Firebase project settings
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Backend Server Configuration
NODE_ENV=development


# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Session Configuration
# IMPORTANT: Change this to a long, random string in production
SESSION_SECRET=change-this-secret-in-production-use-a-long-random-string

# Gemini API Configuration (SERVER-SIDE ONLY)
# This key is used by the backend proxy to make secure API calls
# NEVER expose this key in client-side code or environment variables with VITE_ prefix
# Requirements: 5.1, 5.2, 5.4 - Backend API security
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Configuration (for authentication)
JWT_SECRET=your-secret-key-change-in-production
